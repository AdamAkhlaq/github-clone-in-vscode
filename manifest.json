{
	"manifest_version": 3,
	"name": "Clone Anywhere for GitHub",
	"version": "1.1.0",
	"description": "Clone any GitHub repo into VS Code, Cursor, Windsurf, VSCodium, or Insiders — or download it as a .zip. One click, no terminal.",

	"permissions": ["storage"],

	"content_scripts": [
		{
			"matches": ["https://github.com/*/*"],
			"js": ["content.js"],
			"run_at": "document_end"
		}
	],

	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"96": "icons/icon96.png",
		"128": "icons/icon128.png"
	},

	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"96": "icons/icon96.png",
			"128": "icons/icon128.png"
		}
	}
}
