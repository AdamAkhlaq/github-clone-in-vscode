{
	"manifest_version": 3,
	"name": "GitHub Clone in VS Code",
	"version": "1.0.0",
	"description": "Adds a 'Clone in VS Code' button to GitHub repositories as if it were a native feature for instant one-click cloning.",

	"permissions": ["storage"],

	"content_scripts": [
		{
			"matches": ["https://github.com/*/*"],
			"js": ["content.js"],
			"run_at": "document_end"
		}
	],

	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"96": "icons/icon96.png",
		"128": "icons/icon128.png"
	},

	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"96": "icons/icon96.png",
			"128": "icons/icon128.png"
		}
	}
}
